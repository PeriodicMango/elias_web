# =============================================================================
# Elias Web Console — Environment Variables
# =============================================================================
# Copy this to .env and fill in values.
# =============================================================================

# --- Required ---
SESSION_SECRET=change-me-to-a-random-string

# --- Discord OAuth ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3457/auth/callback

# --- Server ---
WEB_PORT=3457

# --- Tailscale (optional) ---
# If set, session handoff redirects PWA logins to this HTTPS URL.
TAILSCALE_URL=

# --- eliasCore .env is loaded from ../../../eliasCore/.env ---
# Set API keys and model config there.
